{
  "name": "get-next-version",
  "description": "Bump versions with the help of semantic versioning and pull requests labels",
  "version": "3.0.0",
  "author": "MiguelRipoll23",
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "format:write": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint": "npx eslint . -c ./.github/linters/.eslintrc.yml",
    "test": "git branch -f playground && git checkout playground && npm run package",
    "package": "npx ncc build src/index.ts -o dist --source-map --license licenses.txt"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MiguelRipoll23/get-next-version.git"
  },
  "bugs": {
    "url": "https://github.com/MiguelRipoll23/get-next-version/issues"
  },
  "keywords": [
    "bump",
    "version",
    "action"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "latest",
    "@actions/github": "latest",
    "semver": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "@vercel/ncc": "latest",
    "eslint": "latest",
    "eslint-plugin-github": "latest",
    "eslint-plugin-jsonc": "latest",
    "eslint-plugin-prettier": "latest",
    "prettier": "latest",
    "typescript": "latest"
  }
}
